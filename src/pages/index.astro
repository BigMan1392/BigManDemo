---
import Layout from '../layouts/Layout.astro';
import AnimatedBackground from '../components/AnimatedBackground.jsx';
import FeatureCard from '../components/FeatureCard.jsx';
import TechStack from '../components/TechStack.jsx';
---

<AnimatedBackground client:load />

<Layout title="Home">
	<section class="hero">
		<h1>Welcome to BigManDemo</h1>
		<p class="lead">A stunning, modern website built with Astro v7, React, and cutting-edge web technologies. Deployed instantly on GitHub Pages with automated CI/CD.</p>
		<div class="hero-buttons">
			<a href="https://astro.build" target="_blank" rel="noopener" class="btn">Learn Astro</a>
			<a href="https://github.com/BigMan1392/BigManDemo" target="_blank" rel="noopener" class="btn btn-secondary">View Source Code</a>
		</div>
	</section>

	<section id="features">
		<h2>Why This Stack?</h2>
		<div class="feature-grid">
			<FeatureCard 
				client:visible
				icon="⚡"
				title="Lightning Fast"
				description="Static site generation means blazing-fast load times. No server overhead, just pure performance."
				delay="0"
			/>
			<FeatureCard 
				client:visible
				icon="🚀"
				description="Automated deployment on every push. Your changes go live instantly."
				title="Auto Deploy"
				delay="0.1"
			/>
			<FeatureCard 
				client:visible
				icon="⚛️"
				title="React Ready"
				description="Use interactive React components whenever you need interactivity. Server-side rendering when you don't."
				delay="0.2"
			/>
			<FeatureCard 
				client:visible
				icon="🎨"
				title="Modern Design"
				description="Responsive, accessible, and beautiful. Works perfectly on any device with animations and gradients."
				delay="0.3"
			/>
			<FeatureCard 
				client:visible
				icon="🔐"
				title="Secure by Default"
				description="No backend vulnerabilities. Static hosting means your site is inherently more secure."
				delay="0.4"
			/>
			<FeatureCard 
				client:visible
				icon="📈"
				title="SEO Friendly"
				description="Perfect SEO score out of the box. Fully static HTML means search engines love you."
				delay="0.5"
			/>
		</div>
	</section>

	<TechStack client:visible />

	<section class="cta">
		<h2>Ready to Build Something Amazing?</h2>
		<p>Clone this repository and start building your own stunning website today.</p>
		<a href="https://github.com/BigMan1392/BigManDemo" target="_blank" rel="noopener" class="btn">Get Started on GitHub</a>
	</section>
</Layout>

<style>
	.feature-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2.5rem;
		margin-top: 3rem;
	}

	@media (max-width: 768px) {
		.feature-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
