---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Welcome to Astro">
	<h1>Welcome to Astro v7</h1>
	<p>
		Ready to build something amazing? Start editing and see the magic happen!
	</p>
	<ul>
		<li>Edit <code>src/pages/index.astro</code> to see changes on the page</li>
		<li>Check out the Astro docs at <a href="https://docs.astro.build">docs.astro.build</a></li>
	</ul>
</Layout>

<style>
	main {
		margin: auto;
		padding: 1rem;
		width: 800px;
	}
	h1 {
		color: #ff6b35;
		font-size: 2.5rem;
	}
	code {
		background-color: #f4f4f4;
		padding: 0.25rem 0.5rem;
		border-radius: 0.25rem;
	}
	ul {
		list-style: none;
		padding: 0;
	}
	li {
		margin: 1rem 0;
	}
	a {
		color: #0ea5e9;
		text-decoration: none;
	}
	a:hover {
		text-decoration: underline;
	}
</style>
