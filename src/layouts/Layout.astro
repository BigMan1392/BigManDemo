---
import Navbar from '../components/Navbar.jsx';
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Professional Astro v7 website with React components" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | BigManDemo</title>
	</head>
	<body>
		<Navbar client:load />
		<main class="main-content">
			<slot />
		</main>
		<footer class="footer">
			<div class="footer-content">
				<div class="footer-grid">
					<div>
						<h4>BigManDemo</h4>
						<p>A stunning static site built with modern web technologies.</p>
					</div>
					<div>
						<h4>Quick Links</h4>
						<ul>
							<li><a href="https://astro.build" target="_blank">Astro</a></li>
							<li><a href="https://react.dev" target="_blank">React</a></li>
							<li><a href="https://github.com" target="_blank">GitHub</a></li>
						</ul>
					</div>
					<div>
						<h4>Connect</h4>
						<ul>
							<li><a href="https://github.com/BigMan1392/BigManDemo" target="_blank">GitHub Repo</a></li>
							<li><a href="https://astro.build" target="_blank">Astro Docs</a></li>
						</ul>
					</div>
				</div>
				<div class="footer-bottom">
					<p>&copy; 2025 BigManDemo. All rights reserved.</p>
					<p>Built with ❤️ using Astro v7 and React</p>
				</div>
			</div>
		</footer>
	</body>
</html>
